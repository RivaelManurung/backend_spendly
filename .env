# ─────────────────────────────────────────
# Money Tracker Agent — Environment Config
# Copy to .env and fill in values
# ─────────────────────────────────────────

# ── Database ──────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/money_tracker?sslmode=disable

# (or individual vars if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=money_tracker
DB_SSLMODE=disable

# ── AI Models ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Push Notifications (Firebase) ─────────
FCM_SERVER_KEY=your_fcm_server_key_here

# ── Internal Event Bus ────────────────────
INTERNAL_WEBHOOK_URL=http://localhost:8080
INTERNAL_API_KEY=your_internal_secret_key

# ── Auth ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
JWT_SECRET=your_jwt_secret_min_32_chars

# ── Storage (for OCR images & reports) ────
GCS_BUCKET=your_gcs_bucket_name
GCS_CREDENTIALS_FILE=./credentials/gcs.json

# ── Exchange Rate API ─────────────────────
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key
EXCHANGE_RATE_CACHE_TTL_MINUTES=60

# ── App ───────────────────────────────────
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info
