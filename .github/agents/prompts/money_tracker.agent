name: money-tracker-ai-agent
version: 1.0.0
description: >
  AI-powered money tracker agent. Handles transaction management,
  auto-categorization, budget monitoring, and financial analysis
  using Gemini and GPT-4 as analyst backends.

model:
  primary: gemini-1.5-pro
  fallback: gpt-4o
  analyst: gemini-1.5-pro
  categorizer: gpt-4o-mini

tools:
  - file_system
  - code_execution

memory:
  type: persistent
  scope: per_user
  ttl: 90d

triggers:
  - on: schedule
    cron: "0 8 * * *"
    run: daily_insight_job

  - on: schedule
    cron: "0 0 1 * *"
    run: monthly_snapshot_job

  - on: event
    event: transaction.created
    run: auto_categorize_pipeline

  - on: event
    event: budget.threshold_reached
    run: budget_alert_pipeline

  - on: event
    event: user.message
    run: chat_analyst_pipeline

workflows:

  # ─────────────────────────────────────────────
  # 1. TRANSACTION INPUT PIPELINE
  # ─────────────────────────────────────────────
  transaction_input_pipeline:
    description: Handle all transaction creation paths (manual, OCR, import)
    steps:
      - id: validate_input
        tool: code_execution
        run: internal/transaction/validate.go
        input: $trigger.payload

      - id: ocr_extract
        condition: $input.source == "ocr"
        tool: code_execution
        run: internal/ocr/extract.go
        input: $trigger.payload.image_base64

      - id: currency_normalize
        tool: code_execution
        run: internal/transaction/currency.go
        input: $steps.validate_input.result

      - id: auto_categorize
        tool: code_execution
        run: internal/category/auto_categorize.go
        input: $steps.currency_normalize.result
        llm:
          model: $config.model.categorizer
          prompt_file: agents/prompts/categorize.prompt

      - id: save_transaction
        tool: code_execution
        run: internal/transaction/create.go
        input:
          transaction: $steps.currency_normalize.result
          category_suggestion: $steps.auto_categorize.result

      - id: check_budget
        tool: code_execution
        run: internal/budget/check_threshold.go
        input: $steps.save_transaction.result

      - id: emit_event
        tool: code_execution
        run: pkg/notify/emit.go
        input:
          event: transaction.created
          payload: $steps.save_transaction.result

  # ─────────────────────────────────────────────
  # 2. OCR RECEIPT SCAN PIPELINE
  # ─────────────────────────────────────────────
  ocr_scan_pipeline:
    description: Extract transaction data from receipt image
    steps:
      - id: preprocess_image
        tool: code_execution
        run: internal/ocr/preprocess.go
        input: $trigger.payload.image_base64

      - id: extract_text
        tool: code_execution
        run: internal/ocr/extract.go
        input: $steps.preprocess_image.result

      - id: parse_fields
        llm:
          model: $config.model.primary
          prompt_file: agents/prompts/ocr_parse.prompt
        input:
          raw_text: $steps.extract_text.result

      - id: confirm_with_user
        tool: code_execution
        run: internal/ocr/confirm.go
        input: $steps.parse_fields.result

  # ─────────────────────────────────────────────
  # 3. CSV BANK IMPORT PIPELINE
  # ─────────────────────────────────────────────
  csv_import_pipeline:
    description: Parse and import bank mutation CSV
    steps:
      - id: detect_bank_format
        tool: code_execution
        run: internal/transaction/detect_bank.go
        input: $trigger.payload.file_path

      - id: parse_csv
        tool: file_system
        read: $trigger.payload.file_path

      - id: transform_rows
        tool: code_execution
        run: internal/transaction/transform_csv.go
        input:
          rows: $steps.parse_csv.result
          bank_format: $steps.detect_bank_format.result

      - id: bulk_categorize
        tool: code_execution
        run: internal/category/bulk_categorize.go
        input: $steps.transform_rows.result
        llm:
          model: $config.model.categorizer
          prompt_file: agents/prompts/categorize.prompt
          batch_size: 20

      - id: bulk_save
        tool: code_execution
        run: internal/transaction/bulk_create.go
        input: $steps.bulk_categorize.result

      - id: generate_import_summary
        tool: code_execution
        run: internal/report/import_summary.go
        input: $steps.bulk_save.result

  # ─────────────────────────────────────────────
  # 4. AUTO-CATEGORIZE PIPELINE (event-driven)
  # ─────────────────────────────────────────────
  auto_categorize_pipeline:
    description: AI categorization triggered on transaction.created
    steps:
      - id: fetch_transaction
        tool: code_execution
        run: internal/transaction/get.go
        input: $trigger.payload.transaction_id

      - id: fetch_user_categories
        tool: code_execution
        run: internal/category/list_user.go
        input: $trigger.payload.user_id

      - id: run_classifier
        llm:
          model: $config.model.categorizer
          prompt_file: agents/prompts/categorize.prompt
        input:
          merchant: $steps.fetch_transaction.result.merchant
          description: $steps.fetch_transaction.result.description
          amount: $steps.fetch_transaction.result.amount
          categories: $steps.fetch_user_categories.result

      - id: update_suggestion
        tool: code_execution
        run: internal/category/update_suggestion.go
        input:
          transaction_id: $trigger.payload.transaction_id
          suggestion: $steps.run_classifier.result.category
          confidence: $steps.run_classifier.result.confidence

  # ─────────────────────────────────────────────
  # 5. BUDGET ALERT PIPELINE
  # ─────────────────────────────────────────────
  budget_alert_pipeline:
    description: Send alert when budget threshold reached
    steps:
      - id: fetch_budget_status
        tool: code_execution
        run: internal/budget/get_status.go
        input: $trigger.payload

      - id: generate_alert_message
        llm:
          model: $config.model.primary
          prompt_file: agents/prompts/budget_alert.prompt
        input:
          budget: $steps.fetch_budget_status.result
          threshold: $trigger.payload.threshold_pct

      - id: send_notification
        tool: code_execution
        run: pkg/notify/push.go
        input:
          user_id: $trigger.payload.user_id
          message: $steps.generate_alert_message.result
          type: budget_alert

  # ─────────────────────────────────────────────
  # 6. DAILY INSIGHT JOB (scheduled 08:00)
  # ─────────────────────────────────────────────
  daily_insight_job:
    description: Generate daily spending digest for active users
    steps:
      - id: fetch_active_users
        tool: code_execution
        run: internal/analysis/fetch_active_users.go

      - id: foreach_user
        iterate: $steps.fetch_active_users.result
        steps:
          - id: fetch_yesterday_txns
            tool: code_execution
            run: internal/transaction/list_by_date.go
            input:
              user_id: $item.id
              date: yesterday

          - id: generate_daily_digest
            condition: len($steps.fetch_yesterday_txns.result) > 0
            llm:
              model: $config.model.analyst
              prompt_file: agents/prompts/daily_digest.prompt
            input:
              transactions: $steps.fetch_yesterday_txns.result
              user_currency: $item.currency_preference

          - id: save_insight
            tool: code_execution
            run: internal/ai/save_insight.go
            input:
              user_id: $item.id
              insight_type: daily_digest
              content: $steps.generate_daily_digest.result

          - id: notify_user
            tool: code_execution
            run: pkg/notify/push.go
            input:
              user_id: $item.id
              message: $steps.generate_daily_digest.result.summary
              type: daily_insight

  # ─────────────────────────────────────────────
  # 7. MONTHLY SNAPSHOT + AI ANALYSIS JOB
  # ─────────────────────────────────────────────
  monthly_snapshot_job:
    description: Build analysis snapshot and full AI report every 1st of month
    steps:
      - id: fetch_all_users
        tool: code_execution
        run: internal/analysis/fetch_active_users.go

      - id: foreach_user
        iterate: $steps.fetch_all_users.result
        steps:
          - id: build_snapshot
            tool: code_execution
            run: internal/analysis/build_snapshot.go
            input:
              user_id: $item.id
              period_type: monthly
              offset: -1

          - id: run_ai_analysis
            llm:
              model: $config.model.analyst
              prompt_file: agents/prompts/monthly_analysis.prompt
            input:
              snapshot: $steps.build_snapshot.result

          - id: detect_anomalies
            llm:
              model: $config.model.primary
              prompt_file: agents/prompts/anomaly_detection.prompt
            input:
              snapshot: $steps.build_snapshot.result

          - id: detect_saving_opportunities
            llm:
              model: $config.model.analyst
              prompt_file: agents/prompts/saving_opportunities.prompt
            input:
              snapshot: $steps.build_snapshot.result

          - id: save_all_insights
            tool: code_execution
            run: internal/ai/save_batch_insights.go
            input:
              user_id: $item.id
              snapshot_id: $steps.build_snapshot.result.id
              insights:
                - $steps.run_ai_analysis.result
                - $steps.detect_anomalies.result
                - $steps.detect_saving_opportunities.result

          - id: generate_health_score
            tool: code_execution
            run: internal/analysis/health_score.go
            input: $steps.build_snapshot.result

  # ─────────────────────────────────────────────
  # 8. CHAT ANALYST PIPELINE
  # ─────────────────────────────────────────────
  chat_analyst_pipeline:
    description: Answer user financial questions using their own data
    steps:
      - id: parse_intent
        llm:
          model: $config.model.primary
          prompt_file: agents/prompts/intent_parser.prompt
        input:
          message: $trigger.payload.message

      - id: fetch_relevant_data
        tool: code_execution
        run: internal/analysis/fetch_for_chat.go
        input:
          user_id: $trigger.payload.user_id
          intent: $steps.parse_intent.result
          date_range: $steps.parse_intent.result.date_range
          categories: $steps.parse_intent.result.categories

      - id: generate_answer
        llm:
          model: $config.model.analyst
          prompt_file: agents/prompts/chat_analyst.prompt
        input:
          user_message: $trigger.payload.message
          financial_data: $steps.fetch_relevant_data.result
          user_currency: $trigger.payload.user_currency

      - id: return_response
        tool: code_execution
        run: internal/ai/format_chat_response.go
        input: $steps.generate_answer.result

  # ─────────────────────────────────────────────
  # 9. REPORT EXPORT PIPELINE
  # ─────────────────────────────────────────────
  report_export_pipeline:
    description: Generate PDF or CSV report for given period
    steps:
      - id: fetch_data
        tool: code_execution
        run: internal/report/fetch_period_data.go
        input: $trigger.payload

      - id: generate_report
        tool: code_execution
        run: internal/report/generate.go
        input:
          data: $steps.fetch_data.result
          format: $trigger.payload.format
          include_ai_summary: true

      - id: write_file
        tool: file_system
        write:
          path: tmp/reports/$trigger.payload.user_id/$trigger.payload.filename
          content: $steps.generate_report.result

      - id: return_download_url
        tool: code_execution
        run: internal/report/sign_url.go
        input: $steps.write_file.result

error_handling:
  on_llm_failure:
    retry: 2
    fallback_model: $config.model.fallback
  on_db_failure:
    retry: 3
    backoff: exponential
  on_step_failure:
    notify: ops_channel
    log_level: error

logging:
  level: info
  include_llm_inputs: false
  include_llm_outputs: false
  redact_fields:
    - access_token
    - refresh_token
    - amount
